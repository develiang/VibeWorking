<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 主色调 -->
    <Color x:Key="PrimaryColor">#FFE94560</Color>
    <Color x:Key="SecondaryColor">#FF00D9FF</Color>

    <!-- 背景色 -->
    <Color x:Key="WindowBgColor">#FF1A1A2E</Color>
    <Color x:Key="CardBgColor">#FF2A2A3E</Color>
    <Color x:Key="CardAltBgColor">#FF1E1E32</Color>
    <Color x:Key="HeatMapBgColor">#FF0A0A14</Color>

    <!-- 控件色 -->
    <Color x:Key="ControlBgColor">#FF2A2A3E</Color>
    <Color x:Key="ControlHoverBgColor">#FF4A4A68</Color>
    <Color x:Key="ControlPressedBgColor">#FF2E2E42</Color>
    <Color x:Key="BorderColor">#FF3B3B54</Color>
    <Color x:Key="AccentButtonColor">#FFE94560</Color>
    <Color x:Key="AccentButtonHoverColor">#FFFF6B81</Color>
    <Color x:Key="AccentButtonPressedColor">#FFC73E54</Color>
    <Color x:Key="NavButtonHoverFgColor">#FFE94560</Color>

    <!-- 文字色 -->
    <Color x:Key="TextPrimaryColor">#FFFFFFFF</Color>
    <Color x:Key="TextSecondaryColor">#FFCCCCDD</Color>
    <Color x:Key="TextMutedColor">#FF8B8B9E</Color>
    <Color x:Key="TextDimColor">#FF6B6B80</Color>

    <!-- 统计数据颜色 -->
    <Color x:Key="StatMouseColor">#FF2196F3</Color>
    <Color x:Key="StatClickColor">#FF4CAF50</Color>
    <Color x:Key="StatKeyColor">#FFFF9800</Color>

    <!-- 画笔 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBgColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBgColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="CardAltBgBrush" Color="{StaticResource CardAltBgColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="HeatMapBgBrush" Color="{StaticResource HeatMapBgColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="ControlBgBrush" Color="{StaticResource ControlBgColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="ControlHoverBgBrush" Color="{StaticResource ControlHoverBgColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="ControlPressedBgBrush" Color="{StaticResource ControlPressedBgColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="AccentButtonBrush" Color="{StaticResource AccentButtonColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="AccentButtonHoverBrush" Color="{StaticResource AccentButtonHoverColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="AccentButtonPressedBrush" Color="{StaticResource AccentButtonPressedColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDimColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="StatMouseBrush" Color="{StaticResource StatMouseColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="StatClickBrush" Color="{StaticResource StatClickColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="StatKeyBrush" Color="{StaticResource StatKeyColor}"></SolidColorBrush>
    <SolidColorBrush x:Key="NavButtonHoverFgBrush" Color="{StaticResource NavButtonHoverFgColor}"></SolidColorBrush>
</ResourceDictionary>
