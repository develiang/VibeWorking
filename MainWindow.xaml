<Window x:Class="InputStats.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input Stats"
        Height="280"
        Width="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontSize="14"
        Background="#FFF5F5F5">
    <StackPanel Margin="25" VerticalAlignment="Center">
        <TextBlock FontSize="18" FontWeight="Bold" Margin="0,0,0,20" Text="输入统计" Foreground="#FF333333"/>

        <Grid Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="鼠标移动:" Foreground="#FF555555"/>
            <TextBlock Grid.Column="1" Text="{Binding Cm, StringFormat=' {0:F2} cm'}" FontWeight="SemiBold" Foreground="#FF2196F3"/>
        </Grid>

        <Grid Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="鼠标点击:" Foreground="#FF555555"/>
            <TextBlock Grid.Column="1" Text="{Binding Clicks, StringFormat=' {0}'}" FontWeight="SemiBold" Foreground="#FF4CAF50"/>
        </Grid>

        <Grid Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="键盘按键:" Foreground="#FF555555"/>
            <TextBlock Grid.Column="1" Text="{Binding Keys, StringFormat=' {0}'}" FontWeight="SemiBold" Foreground="#FFFF9800"/>
        </Grid>

        <Grid Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="今日已赚:" Foreground="#FF555555"/>
            <TextBlock Grid.Column="1" Text="{Binding EarningsToday, StringFormat=' ¥{0:F4}'}" FontWeight="SemiBold" Foreground="#FFE91E63"/>
        </Grid>

        <Grid Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="本月已赚:" Foreground="#FF555555"/>
            <TextBlock Grid.Column="1" Text="{Binding EarningsMonth, StringFormat=' ¥{0:F4}'}" FontWeight="SemiBold" Foreground="#FF9C27B0"/>
        </Grid>

        <Button Content="重置统计" Click="Reset_Click" Margin="0,20,0,0" Padding="10,6"
                Background="#FF2196F3" Foreground="White" BorderThickness="0"
                Cursor="Hand" HorizontalAlignment="Stretch"/>
    </StackPanel>
</Window>
