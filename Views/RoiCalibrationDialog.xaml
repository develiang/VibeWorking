<Window x:Class="InputStats.RoiCalibrationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工作强度校准"
        Width="420"
        Height="Auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI, Microsoft YaHei"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{DynamicResource WindowBgBrush}" CornerRadius="16" Padding="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="工作强度校准" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
            <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"
                       Text="今日工作即将结束，请根据你今天的实际工作强度，给出一个 0.01 - 1.99 的评分。1.00 表示普通强度，接近 1.99 表示非常忙碌。"/>

            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="今日工作时段统计" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="鼠标移动" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock x:Name="CmValue" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource StatMouseBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="鼠标点击" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock x:Name="ClicksValue" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource StatClickBrush}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="键盘按键" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock x:Name="KeysValue" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource StatKeyBrush}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="今日工作强度评分" FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6"/>
            <Border Background="{DynamicResource CardBgBrush}" CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                <StackPanel>
                    <Slider x:Name="RoiSlider" Minimum="0.01" Maximum="1.99" Value="1.00" TickFrequency="0.01" IsSnapToTickEnabled="True" Margin="0,0,0,8"/>
                    <Grid>
                        <TextBlock Text="轻松" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="RoiValueText" Text="1.00" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="忙碌" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock x:Name="ProgressText" Text="校准进度：1 / 3" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="SkipButton" Content="跳过" Click="Skip_Click" Margin="0,0,8,0"
                        Background="{DynamicResource ControlBgBrush}" Foreground="{DynamicResource TextSecondaryBrush}" BorderThickness="0" Padding="24,10" FontSize="14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ControlHoverBgBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="ConfirmButton" Content="确认提交" Click="Confirm_Click"
                        Background="{DynamicResource AccentButtonBrush}" Foreground="{DynamicResource TextPrimaryBrush}" BorderThickness="0" Padding="24,10" FontSize="14" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentButtonHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentButtonPressedBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
